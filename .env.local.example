# Copia este archivo a .env.local y rellena los valores de tu proyecto Firebase
# (Project settings > General para la config web; Project settings > Service accounts
# para la cuenta de servicio del Admin SDK, en https://console.firebase.google.com)

# --- Config pública del SDK cliente (segura de exponer en el navegador) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Credenciales de cuenta de servicio (Admin SDK) — NUNCA exponer al cliente ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
